{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "isolatedModules": true,
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "types": ["node"]
  },
  "include": [
    "electron/**/*",
    "electron.vite.config.ts",
    "vite.config.ts",
    "tailwind.config.ts",
    "postcss.config.cjs",
    "vitest.config.ts",
    "scripts/**/*"
  ]
}
