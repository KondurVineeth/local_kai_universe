{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "useDefineForClassFields": true,
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "noEmit": true,
    "skipLibCheck": true,

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "exactOptionalPropertyTypes": false,
    "forceConsistentCasingInFileNames": true,

    "baseUrl": ".",
    "paths": {
      "@app/*": ["src/app/*"],
      "@shared/*": ["src/shared/*"],
      "@shared/ds": ["src/shared/design-system"],
      "@shared/ds/*": ["src/shared/design-system/*"],
      "@features/shell": ["src/features/shell"],
      "@features/onboarding": ["src/features/onboarding"],
      "@features/chat": ["src/features/chat"],
      "@features/discover": ["src/features/discover"],
      "@features/my-models": ["src/features/my-models"],
      "@features/local-server": ["src/features/local-server"],
      "@features/developer-docs": ["src/features/developer-docs"],
      "@features/remote": ["src/features/remote"],
      "@features/settings": ["src/features/settings"],
      "@electron/*": ["electron/*"]
    }
  },
  "include": ["src/**/*", "tests/**/*"],
  "exclude": ["node_modules", "out", "dist"]
}
